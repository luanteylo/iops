#!/bin/bash

# IOR local execution script (generated from template)
# Record job start time
date "+%Y-%m-%d %H:%M:%S" > job.start

# Load MPI environment if necessary
# Uncomment if needed:
# source /etc/profile
# module purge
# module load mpi/openmpi/4.0.1

# Execute the IOR benchmark
mpirun -np {{ntasks}}  --oversubscribe {{cmd}} 


# Capture exit code
exit_code=$?

# Record job end time
date "+%Y-%m-%d %H:%M:%S" > job.end

# Write status based on exit code
if [ $exit_code -eq 0 ]; then
    echo "SUCCESS" > job.status
else
    echo "ERROR" > job.status
fi
